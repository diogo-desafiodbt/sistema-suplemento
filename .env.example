# =============================================================================
# Desafio Diabetes — variáveis de ambiente
# =============================================================================
# 1. Copie este arquivo:  cp .env.example .env.local
# 2. Preencha os valores abaixo
# 3. Reinicie o servidor: npm run dev
#
# Nunca commite .env.local (já está no .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (obrigatório para rodar o app)
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Chave service_role — só no servidor (APIs admin, webhooks, checkout).
# Nunca exponha no frontend nem em variáveis NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# -----------------------------------------------------------------------------
# Pagamentos — Pagar.me (obrigatório para checkout)
# Dashboard: https://dashboard.pagar.me/
# Use a secret key da API (autenticação Basic).
# -----------------------------------------------------------------------------
PAGARME_API_KEY=sua_pagarme_api_key_aqui

# -----------------------------------------------------------------------------
# Inngest — jobs em background (opcional em dev local)
# Docs: https://www.inngest.com/docs/sdk/environment-variables
# Com `npx inngest-cli@latest dev`, muitas vezes não precisa preencher aqui.
# -----------------------------------------------------------------------------
# INNGEST_EVENT_KEY=7EpSC_--RM2wMoUqVeL_3jSKf8Ebicon2veqcKipE7HvejZZfAvyjZn0rkPCEMg-h-tkor7hviq_ezUQwxL5og
# INNGEST_SIGNING_KEY=signkey-prod-15d9e431d44e6ea2dc3adde64b32c34859544742c49fcb79603e77d47ac901f1

# -----------------------------------------------------------------------------
# E-mail — Resend (opcional; pacote instalado, ainda não usado no código)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_hVNvJnPF_BjH5N7BJGkBaFCHoTF2TcyUD

# -----------------------------------------------------------------------------
# Vercel CLI (opcional; gerado automaticamente por `vercel env pull` / link)
# Não é necessário para `npm run dev` local.
# -----------------------------------------------------------------------------
# VERCEL_OIDC_TOKEN=

# -----------------------------------------------------------------------------
# Supabase local (opcional — só se usar `supabase start` na máquina)
# -----------------------------------------------------------------------------
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
